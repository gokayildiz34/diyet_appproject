# --------------------------------------------------------------------------
# DIYET APP - Ortam Değişkenleri Şablonu (.env.example)
# --------------------------------------------------------------------------
#
# Bu dosya, projenin ihtiyaç duyduğu ortam değişkenlerinin şablonudur.
# Gerçek kullanım için bu dosyayı ".env" olarak kopyalayın ve
# kendi veritabanı bilgilerinizi girin.
#
# Kullanım:
#   1. Bu dosyayı kopyalayın:  cp .env.example .env
#   2. .env dosyasındaki değerleri kendi ayarlarınıza göre düzenleyin
#   3. .env dosyasını asla Git'e pushlamayın (güvenlik riski!)
#
# --------------------------------------------------------------------------

DB_HOST=localhost
DB_NAME=diyet_app
DB_USER=root
DB_PASS=
